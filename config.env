# Configuración de la aplicación PredictHealth
# ⚠️ IMPORTANTE: Cambiar estas configuraciones para producción

# Clave secreta para sesiones (generar nueva para producción)
SECRET_KEY=your-super-secure-secret-key-change-in-production-$(openssl rand -base64 32)

# Entorno de ejecución
FLASK_ENV=development

# URLs de los microservicios
DOCTOR_SERVICE_URL=http://localhost:8000
PATIENT_SERVICE_URL=http://localhost:8001

# Base de datos PostgreSQL
DATABASE_URL=postgresql://admin:admin123@localhost:5432/predicthealth_db

# Configuración de logging
LOG_LEVEL=INFO
LOG_FILE_PATH=/var/log/predicthealth/app.log

# Configuración de seguridad
CORS_ORIGINS=http://localhost:5001,http://localhost:3000
RATE_LIMIT_ENABLED=true

# Configuración de predicciones médicas
PREDICTION_ALGORITHM_VERSION=1.0
RISK_THRESHOLD_HIGH=70
RISK_THRESHOLD_MODERATE=40

# Configuración de monitoreo
HEALTH_CHECK_INTERVAL=30
METRICS_ENABLED=true
